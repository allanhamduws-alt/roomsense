# Input mode: serial (USB) or udp (WiFi)
INPUT_MODE=serial

# Serial port (only used if INPUT_MODE=serial)
# Mac: /dev/tty.usbmodem* or /dev/cu.*
# Linux: /dev/ttyUSB0 or /dev/ttyACM0
SERIAL_PORT=/dev/tty.usbmodem1234

# UDP (only used if INPUT_MODE=udp)
WIFI_UDP_PORT=5005

# Database (inside Docker, use /app/data for persistence)
DATABASE_URL=sqlite:///./data/roomsense.db

# Backend URL (used by frontend)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Docker ports (optional, for Coolify or custom setups)
# BACKEND_PORT=8000
# FRONTEND_PORT=3000
